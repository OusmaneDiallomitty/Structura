# ============================================
# STRUCTURA - Configuration Environnement
# ============================================

# Base de données PostgreSQL (Docker local)
DATABASE_URL="postgresql://structura_admin:structura_dev_password@localhost:5432/structura_dev?schema=public"

# Redis Cache (Docker local)
REDIS_URL="redis://localhost:6379"

# JWT Secrets (CHANGER EN PRODUCTION!)
JWT_SECRET="dev-secret-key-change-in-production-12345"
JWT_REFRESH_SECRET="dev-refresh-secret-key-change-in-production-67890"

# API Configuration
# Backend séparé (recommandé)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Mode mock (true = mocks, false = vrai backend)
NEXT_PUBLIC_USE_MOCK="false"

# Application
NEXT_PUBLIC_APP_NAME="Structura"
NODE_ENV="development"

# ============================================
# PRODUCTION (Décommenter lors du déploiement)
# ============================================

# Supabase PostgreSQL
# DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# Upstash Redis
# REDIS_URL="redis://default:password@xxx.upstash.io:6379"

# JWT Secrets (Générer des secrets forts!)
# JWT_SECRET="votre-secret-production-super-securise"
# JWT_REFRESH_SECRET="votre-refresh-secret-production"

# API URL Production
# NEXT_PUBLIC_API_URL="https://api.structura.app/api"
