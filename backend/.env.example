# ============================================
# STRUCTURA BACKEND - Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Database PostgreSQL (Docker local)
# ⚠️ IMPORTANT : Pas de guillemets sur Windows !
# ⚠️ Port 5433 pour éviter conflit avec PostgreSQL local
DATABASE_URL=postgresql://structura_admin:structura_dev_password@localhost:5433/structura_dev?schema=public

# Redis Cache (Docker local)
REDIS_URL=redis://localhost:6379

# JWT Secrets (CHANGER EN PRODUCTION!)
JWT_SECRET="dev-secret-key-change-in-production-12345"
JWT_REFRESH_SECRET="dev-refresh-secret-key-change-in-production-67890"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS - Frontend URL
FRONTEND_URL="http://localhost:3000"

# Email Service (Resend)
RESEND_API_KEY="re_123456789_your_api_key_here"
EMAIL_FROM="Structura <noreply@structura.app>"

# ============================================
# PRODUCTION
# ============================================

# PORT=3001
# NODE_ENV=production
# DATABASE_URL="postgresql://user:password@db.supabase.co:5432/postgres"
# REDIS_URL="redis://default:password@upstash.io:6379"
